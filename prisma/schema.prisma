// Prisma Schema for BuddyStore Backend
// Run: npx prisma migrate dev --name init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}


// ─────────────────────────────────────────
// Users
// ─────────────────────────────────────────
model User {
  id               String   @id @default(uuid())
  telegramId       BigInt   @unique
  telegramUsername String   @unique
  firstName        String
  lastName         String?
  languageCode     String?
  isBot            Boolean  @default(false)
  passwordHash     String
  role             Role     @default(USER)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  orders           Order[]
  videoDeliveries  VideoDelivery[]
  videoDeliveryJobs VideoDeliveryJob[]
  botVerifyTokens  BotVerifyToken[]

  @@map("users")
}

enum Role {
  USER
  ADMIN
}

// ─────────────────────────────────────────
// Registration Tokens (for bot verification)
// ─────────────────────────────────────────
model RegistrationToken {
  id               String    @id @default(uuid())
  token            String    @unique
  telegramUsername String
  telegramId       BigInt?
  firstName        String?
  lastName         String?
  languageCode     String?
  verified         Boolean   @default(false)
  expiresAt        DateTime
  createdAt        DateTime  @default(now())

  @@map("registration_tokens")
}

// ─────────────────────────────────────────
// Password Reset OTPs (sent via Telegram)
// ─────────────────────────────────────────
model PasswordResetOtp {
  id               String   @id @default(uuid())
  telegramUsername String
  otp              String
  expiresAt        DateTime
  used             Boolean  @default(false)
  createdAt        DateTime @default(now())

  @@map("password_reset_otps")
}

// ─────────────────────────────────────────
// Bots (one per category)
// ─────────────────────────────────────────
model Bot {
  id             String      @id @default(uuid())
  name           String      @unique
  category       Category    @unique
  collectionMode Boolean     @default(false)
  totalVideos    Int         @default(0)
  minVideoCount  Int         @default(10)
  pricePerVideo  Float       @default(5)
  startedUserIds String[]    @default([])   // Telegram user IDs that started this bot
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  videos Videos[]
  orders Order[]

  @@map("bots")
}

enum Category {
  MIXED
  MOM_SON
  SRI_LANKAN
  CCTV
  PUBLIC
  RAPE
}

// ─────────────────────────────────────────
// One-time tokens for verifying per-bot start (used in checkout)
// ─────────────────────────────────────────
model BotVerifyToken {
  id        String    @id @default(uuid())
  token     String    @unique @default(cuid())
  userId    String
  category  Category
  verified  Boolean   @default(false)
  expiresAt DateTime
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("bot_verify_tokens")
}

// ─────────────────────────────────────────
// Videos stored per bot
// ─────────────────────────────────────────
model Videos {
  id           String   @id @default(uuid())
  fileId       String   @unique  // Telegram file_id
  thumbnailUrl String?           // Cloudinary thumbnail URL (extracted on upload)
  category     Category
  botId        String
  collectedAt  DateTime @default(now())

  bot             Bot             @relation(fields: [botId], references: [id])
  videoDeliveries VideoDelivery[]

  @@map("videos")
}

// ─────────────────────────────────────────
// Orders
// ─────────────────────────────────────────
model Order {
  id           String      @id @default(uuid())
  userId       String
  botId        String
  category     Category
  videoCount   Int
  priceAmount  Float       @default(0)
  receiptUrl   String
  status       OrderStatus @default(PENDING)
  confirmedAt  DateTime?
  completedAt  DateTime?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  user            User            @relation(fields: [userId], references: [id])
  bot             Bot             @relation(fields: [botId], references: [id])
  videoDeliveries VideoDelivery[]
  videoDeliveryJobs VideoDeliveryJob[]

  @@map("orders")
}

enum OrderStatus {
  PENDING      // Receipt uploaded, waiting for admin
  CONFIRMED    // Admin confirmed payment, bot will start
  DELIVERING   // Bot is actively sending videos
  COMPLETED    // All videos sent
  REJECTED     // Admin rejected the order
}

// ─────────────────────────────────────────
// Video Deliveries (tracks what was sent to whom)
// ─────────────────────────────────────────
model VideoDelivery {
  id          String   @id @default(uuid())
  orderId     String
  videoId     String
  userId      String
  deliveredAt DateTime @default(now())

  order Order  @relation(fields: [orderId], references: [id])
  video Videos @relation(fields: [videoId], references: [id])
  user  User   @relation(fields: [userId], references: [id])

  @@unique([videoId, userId]) // A video can only be sent once per user
  @@map("video_deliveries")
}

// ─────────────────────────────────────────
// Postgres Background Queue for Video Delivery
// ─────────────────────────────────────────
model VideoDeliveryJob {
  id              String             @id @default(uuid())
  orderId         String
  userId          String
  userTelegramId  BigInt
  category        Category
  videoCount      Int

  status          DeliveryJobStatus  @default(PENDING)
  attempts        Int                @default(0)
  progress        Int                @default(0)
  error           String?
  
  lockedUntil     DateTime?

  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  order           Order              @relation(fields: [orderId], references: [id])
  user            User               @relation(fields: [userId], references: [id])

  @@map("video_delivery_jobs")
}

enum DeliveryJobStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

// ─────────────────────────────────────────
// Special Bot — Free video collections delivered via deep link
// ─────────────────────────────────────────
// ─────────────────────────────────────────
// Free PDFs
// ─────────────────────────────────────────

model PdfCategory {
  id            String           @id @default(uuid())
  slug          String           @unique  // "stories", "comics"
  title         String
  order         Int              @default(0)
  createdAt     DateTime         @default(now())

  subcategories PdfSubCategory[]

  @@map("pdf_categories")
}

model PdfSubCategory {
  id         String      @id @default(uuid())
  slug       String      @unique  // "expert", "mother_son", etc.
  title      String
  order      Int         @default(0)
  categoryId String
  category   PdfCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  series PdfSeries[]

  @@map("pdf_subcategories")
}

model PdfSeries {
  id            String         @id @default(uuid())
  slug          String         @unique  // "janeleyen", "mayavi"
  title         String
  description   String?
  bannerUrl     String?        // Cloudinary URL
  subcategoryId String
  subcategory   PdfSubCategory @relation(fields: [subcategoryId], references: [id], onDelete: Cascade)
  pdfs          FreePdf[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@map("pdf_series")
}

model FreePdf {
  id        String    @id @default(uuid())
  title     String
  fileUrl   String    // Cloudinary raw URL
  fileSize  String?   // e.g. "345 KB"
  order     Int       @default(0)  // for sorting within a series
  seriesId  String
  series    PdfSeries @relation(fields: [seriesId], references: [id], onDelete: Cascade)
  createdAt DateTime  @default(now())

  @@map("free_pdfs")
}

// ─────────────────────────────────────────
model SpecialCollection {
  id             String   @id @default(uuid())
  slug           String   @unique   // e.g. "anu_kanu" — used in deep link
  title          String             // e.g. "Anu Kanu"
  description    String?
  banner         String?            // URL (uploaded manually to admin)
  trendingTag    String   @default("Trending")
  collectionMode Boolean  @default(false)  // When ON, admin can upload videos
  totalVideos    Int      @default(0)
  order          Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  videos SpecialVideo[]

  @@map("special_collections")
}

model SpecialVideo {
  id           String   @id @default(uuid())
  fileId       String   @unique   // Telegram file_id
  thumbnailUrl String?            // Cloudinary thumbnail URL (extracted on upload)
  collectionId String
  collectedAt  DateTime @default(now())

  collection SpecialCollection @relation(fields: [collectionId], references: [id])

  @@map("special_videos")
}
