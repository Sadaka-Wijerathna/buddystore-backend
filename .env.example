# ============================
# BuddyStore Backend Config
# ============================

# Server
PORT=4000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=7d

# Database (PostgreSQL)
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/buddystore?schema=public"

# Redis (for BullMQ job queues)
REDIS_URL=redis://localhost:6379

# Upload directory (for payment receipts)
UPLOAD_DIR=uploads

# ============================
# Telegram Bots
# ============================

# Main bot (for registration verification)
MAIN_BOT_TOKEN=your_main_bot_token_here

# Category bots
BOT_MIXED_TOKEN=your_mixed_bot_token_here
BOT_MOM_SON_TOKEN=your_mom_son_bot_token_here
BOT_SRI_LANKAN_TOKEN=your_sri_lankan_bot_token_here
BOT_CCTV_TOKEN=your_cctv_bot_token_here
BOT_PUBLIC_TOKEN=your_public_bot_token_here
BOT_RAPE_TOKEN=your_rape_bot_token_here
