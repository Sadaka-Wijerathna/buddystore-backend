# ============================
# BuddyStore Backend Config
# Copy this file to .env and fill in your values
# ============================

# Server
PORT=4000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=7d

# Database (PostgreSQL - Neon.tech)
DATABASE_URL="postgresql://USER:PASSWORD@HOST/neondb?sslmode=require&channel_binding=require"

# Upload directory (for payment receipts)
UPLOAD_DIR=uploads

# Cloudinary (for receipt image uploads)
# Required — receipt uploads will fail without these.
# Get credentials at: https://console.cloudinary.com/settings/api-keys
CLOUDINARY_CLOUD_NAME=your_cloud_name_here
CLOUDINARY_API_KEY=your_api_key_here
CLOUDINARY_API_SECRET=your_api_secret_here

# ============================
# Telegram Bots
# ============================

# Main bot (for registration verification)
MAIN_BOT_TOKEN=your_main_bot_token_here

# Category bots
BOT_MIXED_TOKEN=your_mixed_bot_token_here
BOT_MOM_SON_TOKEN=your_mom_son_bot_token_here
BOT_SRI_LANKAN_TOKEN=your_sri_lankan_bot_token_here
BOT_CCTV_TOKEN=your_cctv_bot_token_here
BOT_PUBLIC_TOKEN=your_public_bot_token_here
BOT_RAPE_TOKEN=your_rape_bot_token_here

# Special bot (free video collections via deep link)
BOT_SPECIAL_TOKEN=your_special_bot_token_here
